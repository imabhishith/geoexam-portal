rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // KEY FIX: added exists() check before get() so new users
    // creating their first document don't trigger a read on a
    // non-existent doc, which previously caused the write to fail.
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Users ──
    match /users/{userId} {
      allow read:   if isAuth();
      allow create: if isOwner(userId);           // new signup writes their own doc
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Questions ──
    match /questions/{questionId} {
      allow read:                   if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // ── Exams ──
    match /exams/{examId} {
      allow read:                   if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // ── Attempts ──
    match /attempts/{attemptId} {
      allow read: if isAuth() && (
        resource.data.status == 'submitted' ||
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuth() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }
  }
}
